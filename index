document.getElementById('backBtn').addEventListener('click',goBack);
document.getElementById('btnTruth').addEventListener('click',()=>drawCard('truth'));
document.getElementById('btnDare').addEventListener('click',()=>drawCard('dare'));
document.getElementById('togTruth').addEventListener('click',()=>setType('truth'));
document.getElementById('togDare').addEventListener('click',()=>setType('dare'));
document.getElementById('togNormal').addEventListener('click',()=>setFormMode('normal'));
document.getElementById('togPicante').addEventListener('click',()=>setFormMode('picante'));
document.getElementById('togExtremo').addEventListener('click',()=>setFormMode('extremo'));
document.getElementById('submitBtn').addEventListener('click',submitCard);
document.getElementById('captchaRefresh').addEventListener('click',generateCaptcha);
document.querySelectorAll('.filter-tab').forEach(btn=>{
  btn.addEventListener('click',()=>filterList(btn.dataset.filter,btn));
});

init();
