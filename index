async function init() {
  updateProgress();
  generateCaptcha();
  await seedStarterCards();
  listenToCards();
  trackPlayer();
}

async function seedStarterCards() {
  try {
    const versionRef = doc(db, 'meta', 'seed');
    const versionSnap = await getDoc(versionRef);
    if (versionSnap.exists() && versionSnap.data().version === 2) return;
    // Borrar starters viejos
    const snap = await getDocs(collection(db, CARDS_COL));
    for (const d of snap.docs.filter(d => d.data().starter === true)) {
      await deleteDoc(doc(db, CARDS_COL, d.id));
    }
    // Insertar nuevos
    for (const c of starterCards) {
      await addDoc(collection(db, CARDS_COL), {...c, createdAt:serverTimestamp(), starter:true});
    }
    await setDoc(versionRef, { version: 2 });
  } catch(e) { console.error(e); }
}

function listenToCards() {
  const q = query(collection(db, CARDS_COL), orderBy('createdAt','asc'));
  onSnapshot(q, snap => {
    allCards = snap.docs.map(d => ({id:d.id,...d.data()}));
    updateModeCounts();
    if (currentMode) { updateStats(); renderList(); }
    showConn(true);
  }, err => { console.error(err); showConn(false); });
}

async function trackPlayer() {
  try {
    const ref = doc(db,'players',playerId);
    const snap = await getDoc(ref);
    if (!snap.exists()) {
      await setDoc(ref, {joinedAt:serverTimestamp()});
      const sr = doc(db,'meta','stats');
      try { await updateDoc(sr, {players:increment(1)}); } catch { await setDoc(sr,{players:1}); }
    }
    const ss = await getDoc(doc(db,'meta','stats'));
    if (ss.exists()) document.getElementById('statPlayers').textContent = ss.data().players || 1;
  } catch(e) { console.error(e); }
}

function updateModeCounts() {
  ['normal','picante','extremo'].forEach(m => {
    const n = allCards.filter(c => c.mode === m).length;
    const el = document.getElementById('count' + m.charAt(0).toUpperCase() + m.slice(1));
    if (el) el.innerHTML = n + '<small>cartas</small>';
  });
}

function enterMode(mode) {
  currentMode = mode;
  selectedFormMode = mode;
  const badge = document.getElementById('modeBadge');
  badge.textContent = MODE_LABELS[mode];
  badge.className = 'current-mode-badge badge-' + mode;
  document.getElementById('modeStatsMini').textContent = allCards.filter(c=>c.mode===mode).length + ' cartas';
  document.getElementById('screenMode').classList.remove('active');
  document.getElementById('screenGame').classList.add('active');
  setFormMode(mode);
  updateStats(); renderList(); updateProgress();
  window.scrollTo(0,0);
}

function goBack() {
  currentMode = null;
  document.getElementById('screenGame').classList.remove('active');
  document.getElementById('screenMode').classList.add('active');
  document.getElementById('cardWrap').innerHTML = '<div class="card-empty"><div class="icon">🎲</div><p>Elegí <strong>Verdad</strong> o <strong>Reto</strong> para empezar</p></div>';
  window.scrollTo(0,0);
}

function updateStats() {
  const f = allCards.filter(c => c.mode === currentMode);
  document.getElementById('statTotal').textContent = f.length;
  document.getElementById('statTruths').textContent = f.filter(c=>c.type==='truth').length;
  document.getElementById('statDares').textContent = f.filter(c=>c.type==='dare').length;
}

function updateProgress() {
  const pct = Math.min(100,(myPlays/PLAYS_TO_UNLOCK)*100);
  document.getElementById('progressFill').style.width = pct+'%';
  document.getElementById('progressText').textContent = myPlays+' / '+PLAYS_TO_UNLOCK;
  if (myPlays >= PLAYS_TO_UNLOCK) {
    document.getElementById('addSection').classList.remove('locked');
    document.getElementById('unlockNote').innerHTML = '🔓 <span>¡Desbloqueado!</span> Podés agregar tus propias cartas';
  } else {
    document.getElementById('addSection').classList.add('locked');
    const left = PLAYS_TO_UNLOCK - myPlays;
    document.getElementById('playsLeft').textContent = left;
    document.getElementById('unlockNote').innerHTML = 'Jugá <span>'+left+'</span> '+(left===1?'vez más':'veces más')+' para poder agregar cartas';
  }
}

function drawCard(type) {
  const pool = allCards.filter(c => c.type===type && c.mode===currentMode);
  if (!pool.length) { showToast('¡No hay cartas de este tipo en este modo!','info'); return; }
  renderCard(pool[Math.floor(Math.random()*pool.length)]);
  myPlays++; localStorage.setItem('vr-plays', myPlays); updateProgress();
}

function renderCard(card) {
  const isT = card.type==='truth';
  const by = card.starter ? 'Carta base' : 'Por '+(card.author||'Anónimo');
  const m = card.mode || 'normal';
  document.getElementById('cardWrap').innerHTML = `
    <div class="card ${isT?'truth-card':'dare-card'}">
      <div class="card-top">
        <div class="card-type"><span class="card-type-dot"></span>${isT?'VERDAD':'RETO'}</div>
        <span class="card-mode-pill pill-${m}">${MODE_LABELS[m]}</span>
      </div>
      <div class="card-text">${esc(card.text)}</div>
      <div class="card-meta"><span>${by}</span><span>${allCards.filter(c=>c.type===card.type&&c.mode===currentMode).length} cartas</span></div>
    </div>`;
}

function setType(type) {
  selectedType = type;
  document.getElementById('togTruth').className = 'tog-btn'+(type==='truth'?' active-truth':'');
  document.getElementById('togDare').className = 'tog-btn'+(type==='dare'?' active-dare':'');
}

function setFormMode(mode) {
  selectedFormMode = mode;
  document.getElementById('togNormal').className = 'tog-btn'+(mode==='normal'?' active-normal':'');
  document.getElementById('togPicante').className = 'tog-btn'+(mode==='picante'?' active-picante':'');
  document.getElementById('togExtremo').className = 'tog-btn'+(mode==='extremo'?' active-extremo':'');
}

function generateCaptcha() {
  const ops = [
    ()=>{const a=Math.ceil(Math.random()*9),b=Math.ceil(Math.random()*9);return[`${a} + ${b}`,a+b];},
    ()=>{const a=Math.ceil(Math.random()*5)+5,b=Math.ceil(Math.random()*5);return[`${a} - ${b}`,a-b];},
    ()=>{const a=Math.ceil(Math.random()*5),b=Math.ceil(Math.random()*5);return[`${a} x ${b}`,a*b];},
  ];
  const [q,ans] = ops[Math.floor(Math.random()*ops.length)]();
  captchaAnswer = ans;
  document.getElementById('captchaQuestion').textContent = '¿Cuánto es '+q+'?';
  document.getElementById('captchaAnswer').value = '';
  document.getElementById('captchaAnswer').classList.remove('error');
}

async function submitCard() {
  if (myPlays < PLAYS_TO_UNLOCK) return;
  const text = document.getElementById('cardText').value.trim();
  const author = document.getElementById('authorName').value.trim() || 'Anónimo';
  if (!text) { showToast('Escribí algo primero 👀','info'); return; }
  if (text.length < 10) { showToast('Muy corto, escribí más ✏️','info'); return; }
  const userAns = parseInt(document.getElementById('captchaAnswer').value);
  if (isNaN(userAns) || userAns !== captchaAnswer) {
    document.getElementById('captchaAnswer').classList.add('error');
    setTimeout(()=>document.getElementById('captchaAnswer').classList.remove('error'),500);
    showToast('Respuesta incorrecta 🤖','error'); generateCaptcha(); return;
  }
  const btn = document.getElementById('submitBtn');
  btn.disabled=true; btn.textContent='Guardando...';
  try {
    const newCard = {type:selectedType,mode:selectedFormMode,text,author,playerId,createdAt:serverTimestamp(),starter:false};
    const ref = await addDoc(collection(db,CARDS_COL), newCard);
    renderCard({...newCard,id:ref.id});
    document.getElementById('cardText').value='';
    document.getElementById('authorName').value='';
    generateCaptcha();
    showToast('¡Carta agregada y en juego! 🎉','success');
    document.getElementById('cardWrap').scrollIntoView({behavior:'smooth',block:'center'});
  } catch(e) { console.error(e); showToast('Error al guardar, intentá de nuevo','error'); }
  btn.disabled=false; btn.textContent='AGREGAR AL MAZO →';
}

function filterList(type, el) {
  currentFilter = type;
  document.querySelectorAll('.filter-tab').forEach(b => b.className='filter-tab');
  el.className = 'filter-tab f-active-'+type;
  renderList();
}

function renderList() {
  const list = document.getElementById('listItems');
  let f = allCards.filter(c=>c.mode===currentMode);
  if (currentFilter!=='all') f=f.filter(c=>c.type===currentFilter);
  f = [...f].reverse();
  if (!f.length) { list.innerHTML='<div class="list-empty">No hay cartas todavía en este modo</div>'; return; }
  list.innerHTML = f.map(c=>`
    <div class="list-item">
      <span class="badge ${c.type==='truth'?'badge-t':'badge-d'}">${c.type==='truth'?'V':'R'}</span>
      <div>
        <div class="list-item-text">${esc(c.text)}</div>
        <div class="list-item-by">${c.starter?'Carta base':'— '+(c.author||'Anónimo')}</div>
      </div>
    </div>`).join('');
}

function showToast(msg,type='info') {
  const t=document.getElementById('toast');
  t.textContent=msg; t.className='toast '+type; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}
function showConn(online) {
  const bar=document.getElementById('connBar');
  if (online) { bar.className='conn-bar online'; bar.textContent='🟢 Conectado en tiempo real'; setTimeout(()=>bar.className='conn-bar',3000); }
  else { bar.className='conn-bar offline'; bar.textContent='🔴 Sin conexión'; }
}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

